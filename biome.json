{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/app/(auth)/**",
      "src/app/(customer)/layout.tsx",
      "src/app/(customer)/p/**",
      "src/app/admin/**",
      "src/app/api/auth/**",
      "src/app/api/v1/builds/**",
      "src/app/api/v1/projects/**/builds/**",
      "src/app/api/v1/projects/**/generate/**",
      "src/app/api/v1/runner/**",
      "src/components/app-sidebar.tsx",
      "src/components/ansi-logs.tsx",
      "src/components/build-history.tsx",
      "src/components/nav-projects.tsx",
      "src/components/nav-user.tsx",
      "src/components/project-chat.tsx",
      "src/components/session-context.tsx",
      "src/hooks/**",
      "src/lib/admin.ts",
      "src/lib/auth-common.ts",
      "src/lib/auth.ts",
      "src/lib/env.ts",
      "src/lib/role.ts",
      "src/lib/runner.ts",
      "src/lib/spec.ts",
      "src/lib/system-health.ts",
      "src/lib/templates.ts",
      "src/lib/types.ts",
      "src/lib/utils.ts",
      "src/lib/supabase/**",
      "src/middleware.ts",
      "src/proxy.ts",
      "src/styles/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
